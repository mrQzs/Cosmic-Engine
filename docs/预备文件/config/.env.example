# ═══════════════════════════════════════════════════════════
#  CyberGeek 宇宙博客 — 环境变量模板
# ═══════════════════════════════════════════════════════════
#
#  使用方法：复制此文件为 .env 并填入实际值
#  cp .env.example .env
#
#  注意：带 NEXT_PUBLIC_ 前缀的变量会暴露给浏览器端，
#        请勿在此类变量中放置敏感信息。

# ========== 数据库 ==========
# PostgreSQL 连接字符串（pgvector 扩展需要 PostgreSQL 16+）
DATABASE_URL=postgresql://cybergeek:password@localhost:5432/cybergeek?sslmode=disable
# 连接池最大连接数（根据服务器 CPU 核心数调整，推荐 CPU*2+1）
DB_MAX_CONNS=25
# 连接池最小空闲连接数
DB_MIN_CONNS=5

# Docker Compose 用（postgres 容器初始化）
POSTGRES_USER=cybergeek
POSTGRES_PASSWORD=password
POSTGRES_DB=cybergeek

# ========== Redis ==========
# Redis Stack 连接地址（含 Bloom Filter + JSON 模块）
REDIS_URL=redis://localhost:6379/0

# ========== JWT ==========
# JWT 签名密钥（生产环境必须更换为随机 64 字符字符串）
# 生成方法: openssl rand -hex 32
JWT_SECRET=change-me-to-random-64-chars
# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=24

# ========== 服务器 ==========
# Go/Gin 后端监听端口
SERVER_PORT=8080
# 监听地址（0.0.0.0 允许外部访问，127.0.0.1 仅本机）
SERVER_HOST=0.0.0.0
# Gin 运行模式：debug（开发，含调试日志）| release（生产）
GIN_MODE=debug

# ========== 前端 ==========
# 后端 API 基础地址（NEXT_PUBLIC_ 前缀会暴露给浏览器）
NEXT_PUBLIC_API_URL=http://localhost:8080
# WebSocket 连接地址（用于实时通知、在线状态等）
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
# CDN 地址（留空则使用本地存储路径提供静态资源）
NEXT_PUBLIC_CDN_URL=
# 站点名称（显示在标签页标题、导航栏等）
NEXT_PUBLIC_SITE_NAME=CyberGeek
# 站点副标题（显示在首页 hero 区域）
NEXT_PUBLIC_SITE_SUBTITLE=CyberCode Chronicles

# ========== 存储 ==========
# 文件存储后端类型：local | s3 | r2 | oss | minio
STORAGE_TYPE=local
# 本地存储路径（STORAGE_TYPE=local 时生效）
STORAGE_LOCAL_PATH=./uploads
# S3 兼容存储配置（R2/OSS/MinIO 也使用这些字段）
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# 区域（Cloudflare R2 使用 auto）
S3_REGION=auto

# ========== 邮件（后续启用） ==========
# SMTP 服务器地址
SMTP_HOST=
# SMTP 端口（587=STARTTLS，465=SSL）
SMTP_PORT=587
# SMTP 认证用户名
SMTP_USER=
# SMTP 认证密码
SMTP_PASSWORD=
# 发件人地址
SMTP_FROM=noreply@wo.city

# ========== 安全 ==========
# API Key 加盐（用于生成/验证 API 密钥的 HMAC 盐值）
API_KEY_SALT=change-me
# 管理后台路由前缀（通过隐蔽路径提供基本安全性，生产环境应配合 IP 白名单）
ADMIN_ROUTE_PREFIX=/admin_199209173332

# ========== 向量嵌入 ==========
# 是否启用向量嵌入（用于语义搜索、相关文章推荐）
EMBEDDING_ENABLED=false
# 外部嵌入服务地址（EMBEDDING_ENABLED=true 时必须配置）
EMBEDDING_API_URL=

# ========== Meilisearch（可选） ==========
# Meilisearch 主密钥（启用 docker-compose 中的 meilisearch 服务时使用）
# MEILI_MASTER_KEY=cybergeek-dev-key
# MEILI_URL=http://localhost:7700

# ========== 监控 ==========
# Sentry DSN（错误追踪，留空则禁用）
SENTRY_DSN=
